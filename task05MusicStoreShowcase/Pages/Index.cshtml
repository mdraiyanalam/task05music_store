@page
@model task05MusicStoreShowcase.Pages.IndexModel

@{
    ViewData["Title"] = "Music Store Showcase";
}

<div class="container mt-4">
    <h1 class="mb-4 text-center">🎵 Music Store Showcase</h1>

    <!-- Toolbar -->
    <div class="row mb-4 bg-light p-3 rounded shadow align-items-end">
        <div class="col-md-3">
            <label class="form-label fw-bold">🌍 Language</label>
            <select class="form-select" id="languageSelect" asp-for="CurrentLanguage">
                <option value="en">English (USA)</option>
                <option value="de">German (Germany)</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label fw-bold">🔑 Seed</label>
            <input type="number" class="form-control" id="seedInput" asp-for="CurrentSeed" />
        </div>
        <div class="col-md-3">
            <label class="form-label fw-bold">❤️ Avg Likes</label>
            <input type="number" step="0.1" class="form-control" id="likesInput" asp-for="AvgLikes" />
        </div>
        <div class="col-md-3">
            <button onclick="applyFilters()" class="btn btn-primary w-100">Apply Changes</button>
        </div>
    </div>

    <!-- Table Container -->
    <div id="tableContainer">
        <partial name="_SongsTable" model="Model" />
    </div>
</div>

@section Scripts {
    <script>
        // Toolbar AJAX
        function applyFilters() {
            const formData = new FormData();
            formData.append("CurrentLanguage", document.getElementById('languageSelect').value);
            formData.append("CurrentSeed", document.getElementById('seedInput').value);
            formData.append("AvgLikes", document.getElementById('likesInput').value);

            fetch('/Index?handler=LoadData', {
                method: 'POST',
                body: formData
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error('Server error: ' + response.status);
                }
                return response.text();
            })
            .then(html => {
                document.getElementById('tableContainer').innerHTML = html;
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Failed to update table. Check console (F12)');
            });
        }

        // Advanced Player JavaScript
        let currentAudio = null;

        function togglePlay(id) {
            const audio = document.getElementById(`audio-${id}`);
            const playBtn = document.getElementById(`playBtn-${id}`);

            if (currentAudio && currentAudio !== audio) {
                currentAudio.pause();
            }

            if (audio.paused) {
                audio.play();
                playBtn.textContent = "⏸ Pause";
                currentAudio = audio;
            } else {
                audio.pause();
                playBtn.textContent = "▶ Play";
            }
        }

        function seekAudio(id) {
            const audio = document.getElementById(`audio-${id}`);
            const progress = document.getElementById(`progress-${id}`);
            if (audio.duration) {
                audio.currentTime = (progress.value / 100) * audio.duration;
            }
        }

        function toggleMute(id) {
            const audio = document.getElementById(`audio-${id}`);
            audio.muted = !audio.muted;
        }

        function changeSpeed(id) {
            const audio = document.getElementById(`audio-${id}`);
            const speed = document.getElementById(`speed-${id}`).value;
            audio.playbackRate = parseFloat(speed);
        }

        function formatTime(seconds) {
            if (!seconds || isNaN(seconds)) return "0:00";
            const min = Math.floor(seconds / 60);
            const sec = Math.floor(seconds % 60);
            return `${min}:${sec < 10 ? '0' : ''}${sec}`;
        }

        function updateProgress() {
            if (!currentAudio) return;
            const id = currentAudio.id.replace('audio-', '');
            const progress = document.getElementById(`progress-${id}`);
            const timeEl = document.getElementById(`time-${id}`);

            if (progress && timeEl && currentAudio.duration) {
                const percent = (currentAudio.currentTime / currentAudio.duration) * 100;
                progress.value = percent || 0;
                timeEl.textContent = `${formatTime(currentAudio.currentTime)} / ${formatTime(currentAudio.duration)}`;
            }
        }

        setInterval(updateProgress, 500);
    </script>
}