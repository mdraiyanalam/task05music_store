@page
@model task05MusicStoreShowcase.Pages.IndexModel

@{
    ViewData["Title"] = "Music Store Showcase";
}

<div class="container mt-4">
    <h1 class="mb-4 text-center">🎵 Music Store Showcase</h1>

    <!-- Toolbar -->
    <div class="row mb-4 bg-light p-3 rounded shadow align-items-end">
        <div class="col-md-3">
            <label class="form-label fw-bold">🌍 Language</label>
            <select class="form-select" id="languageSelect" asp-for="CurrentLanguage">
                <option value="en">English (USA)</option>
                <option value="de">German (Germany)</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label fw-bold">🔑 Seed</label>
            <input type="number" class="form-control" id="seedInput" asp-for="CurrentSeed" />
        </div>
        <div class="col-md-3">
            <label class="form-label fw-bold">❤️ Avg Likes</label>
            <input type="number" step="0.1" class="form-control" id="likesInput" asp-for="AvgLikes" />
        </div>
        <div class="col-md-3">
            <button onclick="applyFilters()" class="btn btn-primary w-100">Apply Changes</button>
            <button onclick="randomSeed()" class="btn btn-outline-secondary w-100 mt-2">🎲 Random Seed</button>
        </div>
    </div>

    <!-- View Tabs -->
    <ul class="nav nav-tabs mb-3">
        <li class="nav-item">
            <button class="nav-link active" id="table-tab" onclick="showTable()">Table View</button>
        </li>
        <li class="nav-item">
            <button class="nav-link" id="gallery-tab" onclick="showGallery()">Gallery View</button>
        </li>
    </ul>

    <!-- Table View -->
    <div id="tableView">
        <partial name="_SongsTable" model="Model" />
    </div>

    <!-- Gallery View -->
    <div id="galleryView" style="display:none;">
        <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4" id="galleryContainer">
            @foreach (var song in Model.AllSongsForGallery)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <div style="height:180px;background:linear-gradient(135deg,#667eea,#764ba2);position:relative;display:flex;align-items:center;justify-content:center;color:white;overflow:hidden;">
                            <div style="text-align:center;padding:20px;">
                                <div style="font-size:60px;margin-bottom:10px;">🎵</div>
                                <h5 style="margin:0;font-weight:bold;">@song.Title</h5>
                                <small>@song.Artist</small>
                            </div>
                        </div>
                        <div class="card-body text-center">
                            <p class="card-text small text-muted">@song.Album • @song.Genre</p>
                            <span class="badge bg-primary">@song.Likes likes</span>
                        </div>
                        <div class="card-footer text-center pt-3">
                            <audio id="audio-@song.Id" preload="metadata" style="display:none;">
                                <source src="/Index?handler=Preview&id=@song.Id" type="audio/mpeg">
                            </audio>
                            <div class="d-flex align-items-center justify-content-center gap-2">
                                <button id="playBtn-@song.Id" onclick="togglePlay(@song.Id)" class="btn btn-success btn-sm">▶ Play</button>
                                <a href="/Index?handler=Preview&id=@song.Id" download class="btn btn-outline-primary btn-sm">⬇</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Toolbar
        function applyFilters() {
            const formData = new FormData();
            formData.append("CurrentLanguage", document.getElementById('languageSelect').value);
            formData.append("CurrentSeed", document.getElementById('seedInput').value);
            formData.append("AvgLikes", document.getElementById('likesInput').value);

            fetch('/Index?handler=LoadData', {
                method: 'POST',
                body: formData
            })
            .then(response => response.text())
            .then(html => document.getElementById('tableView').innerHTML = html)
            .catch(error => console.error('Error:', error));
        }

        function randomSeed() {
            const randomSeed = Math.floor(Math.random() * 9000000000000000000) + 1000000000000000000;
            document.getElementById('seedInput').value = randomSeed;
            applyFilters();
        }

        // View Switching
        function showTable() {
            document.getElementById('tableView').style.display = 'block';
            document.getElementById('galleryView').style.display = 'none';
            document.getElementById('table-tab').classList.add('active');
            document.getElementById('gallery-tab').classList.remove('active');
        }

        function showGallery() {
            document.getElementById('tableView').style.display = 'none';
            document.getElementById('galleryView').style.display = 'block';
            document.getElementById('table-tab').classList.remove('active');
            document.getElementById('gallery-tab').classList.add('active');
        }

        // Pagination
        function changePage(page) {
            if (page < 1 || page > @Model.TotalPages) return;

            const formData = new FormData();
            formData.append("CurrentLanguage", document.getElementById('languageSelect').value);
            formData.append("CurrentSeed", document.getElementById('seedInput').value);
            formData.append("AvgLikes", document.getElementById('likesInput').value);
            formData.append("page", page);

            fetch('/Index?handler=LoadData', {
                method: 'POST',
                body: formData
            })
            .then(response => response.text())
            .then(html => document.getElementById('tableView').innerHTML = html)
            .catch(error => console.error('Error:', error));
        }

        // Full Player with Progress & Time
        let currentAudio = null;

        function togglePlay(id) {
            const audio = document.getElementById(`audio-${id}`);
            const playBtn = document.getElementById(`playBtn-${id}`);

            if (currentAudio && currentAudio !== audio) currentAudio.pause();

            if (audio.paused) {
                audio.play();
                playBtn.textContent = "⏸";
                currentAudio = audio;
            } else {
                audio.pause();
                playBtn.textContent = "▶";
            }
        }

        function seekAudio(id) {
            const audio = document.getElementById(`audio-${id}`);
            const progress = document.getElementById(`progress-${id}`);
            if (audio.duration) {
                audio.currentTime = (progress.value / 100) * audio.duration;
            }
        }

        function updateProgress() {
            if (!currentAudio) return;
            const id = currentAudio.id.replace('audio-', '');
            const progress = document.getElementById(`progress-${id}`);
            const timeEl = document.getElementById(`time-${id}`);

            if (progress && timeEl && currentAudio.duration) {
                const percent = (currentAudio.currentTime / currentAudio.duration) * 100;
                progress.value = percent || 0;
                timeEl.textContent = `${formatTime(currentAudio.currentTime)} / ${formatTime(currentAudio.duration)}`;
            }
        }

        function formatTime(seconds) {
            if (!seconds || isNaN(seconds)) return "0:00";
            const min = Math.floor(seconds / 60);
            const sec = Math.floor(seconds % 60);
            return `${min}:${sec < 10 ? '0' : ''}${sec}`;
        }

        setInterval(updateProgress, 500);
    </script>
}