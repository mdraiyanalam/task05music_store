@page
@model task05MusicStoreShowcase.Pages.IndexModel

@{
    ViewData["Title"] = "Music Store Showcase";
}

<div class="container mt-4">
    <h1 class="mb-4 text-center">🎵 Music Store Showcase</h1>

    <!-- Toolbar -->
    <form method="post" class="mb-4">
        <div class="row bg-light p-3 rounded shadow align-items-end">
            <div class="col-md-3">
                <label class="form-label fw-bold">🌍 Language</label>
                <select class="form-select" asp-for="CurrentLanguage">
                    <option value="en">English (USA)</option>
                    <option value="de">German (Germany)</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold">🔑 Seed</label>
                <input type="number" class="form-control" asp-for="CurrentSeed" />
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold">❤️ Avg Likes</label>
                <input type="number" step="0.1" class="form-control" asp-for="AvgLikes" />
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary w-100">Apply</button>
            </div>
        </div>
    </form>

    <!-- Table with Expandable Player -->
    <h3 class="mb-3">📋 Songs</h3>
    <div class="table-responsive">
        <table class="table table-hover">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Song</th>
                    <th>Artist</th>
                    <th>Album</th>
                    <th>Genre</th>
                    <th>Likes</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var song in Model.Songs)
                {
                    <tr>
                        <td>@song.Id</td>
                        <td><strong>@song.Title</strong></td>
                        <td>@song.Artist</td>
                        <td>@song.Album</td>
                        <td>@song.Genre</td>
                        <td><span class="badge bg-primary">@song.Likes</span></td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary" type="button"
                                    data-bs-toggle="collapse" data-bs-target="#player-@song.Id">
                                ▶ Details
                            </button>
                        </td>
                    </tr>

                    <!-- Expandable Player Row -->
                    <tr class="collapse" id="player-@song.Id">
                        <td colspan="7" class="p-0">
                            <div class="bg-light p-3 border-top">
                                <div class="d-flex align-items-center">
                                    <!-- Fake Album Art -->
                                    <div class="me-4">
                                        <div style="width:80px;height:80px;background:linear-gradient(45deg,#ff6b6b,#4ecdc4);border-radius:8px;display:flex;align-items:center;justify-content:center;color:white;font-size:30px;">
                                            🎵
                                        </div>
                                    </div>

                                    <div class="flex-grow-1">
                                        <h5>@song.Title</h5>
                                        <p class="text-muted mb-1">@song.Artist • @song.Album</p>
                                        <p class="small text-muted">@song.Genre</p>

                                        <!-- Simple Player -->
                                        <div class="d-flex align-items-center gap-3">
                                            <button onclick="playAudio(@song.Id)" class="btn btn-success btn-sm">▶ Play Preview</button>
                                            <input type="range" class="form-range" style="width:300px;" value="30">
                                            <span class="small text-muted">2:12</span>
                                        </div>
                                    </div>

                                    <div class="text-end">
                                        <span class="badge bg-primary">@song.Likes likes</span>
                                    </div>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function playAudio(id) {
            const audio = new Audio(`/Index?handler=Preview&id=${id}`);
            audio.play().catch(() => alert("Audio preview is generating..."));
        }
    </script>
}